generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("client") // client | seller | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  favorites    Favorite[]
  shops        Shop[]
  deliveries   DeliveryPerson[]
  transactions    Transaction[]
  creditRequests  CreditRequest[]
  reviewedCreditRequests CreditRequest[] @relation("CreditReviewer")

  @@index([email])
  @@index([role])
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String
  brand        String
  category     String
  price        Int
  monthlyPrice Int
  rating       Float    @default(0)
  reviews      Int      @default(0)
  inStock      Boolean  @default(true)
  promotion    Boolean  @default(false)
  description  String?
  image        String
  images       String
  creditRates  String?
  slug         String   @unique
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems      OrderItem[]
  favorites       Favorite[]
  stockEntries    ProductStock[]
  boosts          ProductBoost[]
  creditRequests  CreditRequest[]

  @@index([category])
  @@index([brand])
  @@index([slug])
  @@index([shopId])
}

model Order {
  id             String      @id
  date           DateTime    @default(now())
  status         String      @default("pending") // pending | processing | shipped | delivered | cancelled
  total          Int
  userId         Int
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderItem[]
  shippingName   String?
  shippingEmail  String?
  shippingPhone  String?
  shippingAddress String?
  countryId      String?
  cityId         String?
  districtId     String?
  deliveryMethod String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  quantity  Int
  price     Int

  @@index([orderId])
  @@index([productId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Category {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique
  icon String
}

model DeliveryPerson {
  id            String   @id
  name          String
  phone         String
  email         String
  avatar        String
  countryId     String
  cityId        String
  districtId    String
  available     Boolean  @default(true)
  rating        Float    @default(0)
  kycStatus     String   @default("pending") // pending | submitted | approved | rejected | verified
  missionsCount Int      @default(0)
  coordinates   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  missions DeliveryMission[]
  user     User?     @relation(fields: [userId], references: [id])
  userId   Int?

  @@index([cityId])
  @@index([available])
}

model DeliveryMission {
  id               String   @id
  orderId          String   @unique
  deliveryPersonId String?
  deliveryPerson   DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id])
  countryId        String
  cityId           String
  districtId       String
  status           String   @default("pending") // pending | assigned | picked_up | in_transit | delivered | cancelled
  pickupAddress    String
  deliveryAddress  String
  customerName     String
  customerPhone    String
  assignedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([deliveryPersonId])
  @@index([status])
  @@index([cityId])
}

model ProductStock {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  countryId  String
  cityId     String
  districtId String
  quantity   Int      @default(0)

  @@index([productId])
}

model Shop {
  id          String    @id
  sellerId    Int       @unique
  seller      User      @relation(fields: [sellerId], references: [id])
  name        String
  slug        String    @unique
  description String
  phone       String
  email       String
  logo        String
  coverImage  String
  countryId   String
  cityId      String
  districtId  String
  address     String
  category    String  @default("")
  rating      Float     @default(0)
  totalSales  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products        Product[]
  subscriptions   ShopSubscription[]
  boosts          ProductBoost[]
  transactions    Transaction[]
  badges          ShopBadge[]
  creditRequests  CreditRequest[]

  @@index([category])
}

model Plan {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String
  price       Int
  durationDays Int
  maxBoosts   Int      @default(0)
  hasPremiumBadge  Boolean @default(false)
  hasVerifiedBadge Boolean @default(false)
  hasFeaturedBadge Boolean @default(false)
  boostPrice       Int     @default(0)
  isActive         Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscriptions ShopSubscription[]
}

model ShopSubscription {
  id        String   @id
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  planId    Int
  plan      Plan     @relation(fields: [planId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String   @default("active") // active | expired | cancelled
  autoRenew Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([status])
}

model ProductBoost {
  id        String    @id
  productId Int
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopId    String?
  shop      Shop?     @relation(fields: [shopId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String    @default("active") // active | expired
  createdAt DateTime  @default(now())

  @@index([productId])
  @@index([shopId])
  @@index([status])
}

model Transaction {
  id        String   @id
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  amount    Int
  currency  String   @default("XAF")
  type      String   // subscription | boost | manual
  status    String   @default("pending") // pending | completed | failed | refunded
  reference String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model ShopBadge {
  id         String   @id
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type       String   // premium | verified | featured | partner | best_seller
  label      String
  color      String
  icon       String?
  assignedBy String   @default("system") // admin | system | subscription
  assignedAt DateTime @default(now())
  expiresAt  DateTime?

  @@index([shopId])
  @@index([type])
}

model CreditRequest {
  id              String      @id
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  productId       Int
  product         Product     @relation(fields: [productId], references: [id])
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id])
  status          String      @default("pending") // pending | approved | rejected | cancelled
  amountRequested Int
  creditDuration  Int         // number of months
  monthlyPayment  Int
  creditRate      Float       @default(0)
  reviewedBy      Int?
  reviewer        User?       @relation("CreditReviewer", fields: [reviewedBy], references: [id])
  reviewNotes     String?
  reviewedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  guarantors Guarantor[]

  @@index([userId])
  @@index([status])
  @@index([shopId])
  @@index([createdAt])
}

model Guarantor {
  id         String   @id
  creditRequestId String
  creditRequest   CreditRequest @relation(fields: [creditRequestId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  email      String?
  countryId  String
  cityId     String
  districtId String
  address    String?
  idType     String   // CNI | Passeport | Permis
  idDocument String   // uploaded file path
  relationship String // Parent | Conjoint(e) | Ami(e) | Collègue | Autre
  status     String   @default("pending") // pending | verified | rejected
  createdAt  DateTime @default(now())

  @@index([creditRequestId])
}

model Country {
  id   String @id
  name String
  flag String
}

model City {
  id        String @id
  name      String
  countryId String
  x         Int
  y         Int
}

model District {
  id     String @id
  name   String
  cityId String
  x      Int
  y      Int
}

model TaxRate {
  id        Int    @id @default(autoincrement())
  countryId String @unique
  rate      Float
  label     String
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}
