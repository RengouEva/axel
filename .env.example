# Développement (SQLite)
DATABASE_URL="file:./dev.db"
JWT_SECRET="axel-marketplace-jwt-secret-development-key"

# Production (MySQL) - décommente et adapte pour le déploiement
# DATABASE_URL="mysql://utilisateur:motdepasse@hote:3306/nom_base"
# JWT_SECRET="axel-marketplace-jwt-secret-production-2024-secure-key"

# Paiement sécurisé (Flutterwave - recommandé Cameroun) - https://flutterwave.com
# Obtiens tes clés sur le dashboard Flutterwave (Mode Test / Live)
# NEXT_PUBLIC_FLW_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx"
# FLW_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx"

# Alternative: Paystack - https://paystack.com
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
# PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"

# Clé secrète pour initialiser la base (GET /api/setup?key=...)
# Génère une clé forte avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SETUP_SECRET_KEY="ta-cle-secrete-ici"
